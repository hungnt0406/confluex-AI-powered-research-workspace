APP_NAME=Literature Review API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://172.18.64.1:3000
ADMIN_EMAILS=
# Xiaomi MiMo — primary LLM provider (OpenAI-compatible)
XIAOMI_MIMO_API_KEY=
XIAOMI_MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# Chat model for the document-level writer chat (must be a chat-capable Xiaomi model)
XIAOMI_CHAT_MODEL=mimo-v2.5-pro
# Writer chat provider — "xiaomi" (default) or "openrouter"
WRITER_CHAT_PROVIDER=xiaomi
WRITER_CHAT_MAX_TOKENS=16384
WRITER_CHAT_CREDITS_PER_TURN=3
WRITER_CHAT_SESSION_TTL_SECONDS=86400
WRITER_CHAT_CONTEXT_WINDOW_TURNS=6
WRITER_CHAT_MAX_INCLUDED_SECTIONS=4
# Per-request HTTP timeout for the chat LLM call. Multi-section rewrites can
# genuinely take 60-90s; raise if you see "model took too long" replies.
WRITER_CHAT_REQUEST_TIMEOUT_SECONDS=300

# Optional Redis URL for persistent (across restarts) writer chat sessions.
# Leave unset to use the in-memory store.
# REDIS_URL=redis://localhost:6379/0


WRITER_EDITOR_VISION_MODEL=mimo-v2.5



# OpenRouter — used for embeddings (openai/text-embedding-3-small); keep this set
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PDF_ENGINE=native
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# LLM model assignments (used via MiMo when XIAOMI_MIMO_API_KEY is set)
OPENROUTER_MODEL=mimo-v2.5-pro
OPENROUTER_DOCUMENT_MODEL=mimo-v2.5-pro
DEEP_SEARCH_PLANNER_MODEL=mimo-v2.5-pro
DEEP_SEARCH_RESEARCH_MODEL=mimo-v2.5-pro
DEEP_SEARCH_SUMMARIZER_MODEL=mimo-v2-flash
DEEP_SEARCH_WRITER_MODEL=mimo-v2.5-pro
WRITER_SOURCE_RANKER_MODEL=mimo-v2.5-pro
DEEP_SEARCH_VERIFIER_MODEL=mimo-v2-flash
WRITER_SOURCE_RANKER_MODEL=mimo-v2.5-pro

TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
DEEP_SEARCH_MAX_WEB_SEARCHES=5
DEEP_SEARCH_MAX_ITERATIONS=2
DEEP_SEARCH_MAX_RESULTS_PER_QUERY=5
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/literature_review
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/literature_review_test
SEMANTIC_SCHOLAR_API_KEY=
JWT_SECRET_KEY=super-secret-key-that-is-long-enough-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
DEFAULT_YEAR_START=2018
DEFAULT_CANDIDATE_LIMIT=60
DEFAULT_SUMMARY_LIMIT=30
SEARCH_RESULTS_PER_QUERY=10
MINIMUM_ABSTRACT_LENGTH=100
SUMMARY_CONCURRENCY=5
EMBEDDING_DIMENSIONS=256
EXTERNAL_API_TIMEOUT_SECONDS=20
WRITER_GENERATION_TIMEOUT_SECONDS=60
PROJECT_CHAT_FIRST_TOKEN_TIMEOUT_SECONDS=60
PDF_DOWNLOAD_TIMEOUT_SECONDS=20
PAPER_CHUNK_SIZE_CHARS=3000
PAPER_RETRIEVAL_TOP_K=5
REFERENCE_UPLOAD_DIR=data/reference_uploads
REFERENCE_MAX_EXTRACTED_CHARS=120000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
SEPAY_API_KEY=
SEPAY_WEBHOOK_API_KEY=
SEPAY_ACCOUNT_NUMBER=
SEPAY_ACCOUNT_BANK_BIN=
USD_TO_VND_RATE=25500
CREDIT_COST_DEEP_SEARCH=80
CREDIT_COST_WRITER=40
CREDIT_COST_PAPER_CHAT=2
CREDIT_COST_PDF_UPLOAD=5
CREDIT_COST_PIPELINE_RUN=20





