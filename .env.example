# =============================================================================
# LLM Providers (at least one required)
# =============================================================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Models (defaults shown)
DEFAULT_MODEL=gpt-4o
CHEAP_MODEL=gpt-4o-mini

# =============================================================================
# Database
# =============================================================================
# Railway auto-sets this when you add a PostgreSQL addon
DATABASE_URL=postgresql://user:pass@localhost:5432/literaturereview

# =============================================================================
# Data Source API Keys (optional — improves rate limits)
# =============================================================================
# Semantic Scholar: request at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed: email required by NCBI policy. API key optional (3→10 req/sec)
PUBMED_EMAIL=your.email@example.com
PUBMED_API_KEY=

# =============================================================================
# Embedding & Vector Store
# =============================================================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=data/chroma_db

# =============================================================================
# Pipeline Tuning
# =============================================================================
MAX_SEARCH_RESULTS=200
SIMILARITY_THRESHOLD=0.3
TOP_N_PAPERS=20
QUALITY_THRESHOLD=7.0
MAX_QUALITY_RETRIES=2

# Scoring weights (must sum to 1.0)
RELEVANCE_WEIGHT=0.6
CITATION_WEIGHT=0.2
RECENCY_WEIGHT=0.2

# =============================================================================
# General
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================

# =============================================================================



