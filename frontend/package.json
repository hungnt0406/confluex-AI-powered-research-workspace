{
  "name": "a20-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:bounded": "systemd-run --user --scope --unit=a20-next-dev -p MemoryMax=10G -p MemorySwapMax=0 --working-directory=$(pwd) npm run dev",
    "dev:reset": "rm -rf .next/dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "katex": "^0.16.45",
    "next": "^16.2.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-force-graph-2d": "^1.29.1"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.4.39",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.3"
  }
}
